      "selectors": ["button", "a.btn", "a.button", "[role='button']", "input[type='submit']"],
      "condition": "grammar_check"
    },
    "finding": "Button or CTA text contains a grammar/spelling issue",
    "ice": { "impact": 5, "confidence": 7, "ease": 9 },
    "target_selector": "button, a.btn, [role='button']"
  },
  {
    "id": "ux-grammar-heading-text",
    "category": "grammar",
    "check": {
      "type": "text_content",
      "selectors": ["h1", "h2", "h3", "h4"],
      "condition": "grammar_check"
    },
    "finding": "Heading text contains a grammar or capitalisation issue",
    "ice": { "impact": 6, "confidence": 6, "ease": 9 },
    "target_selector": "h1, h2, h3, h4"
  },
  {
    "id": "ux-grammar-empty-links",
    "category": "grammar",
    "check": {
      "type": "text_content",
      "selectors": ["a"],
      "condition": "empty_text"
    },
    "finding": "Link has no visible text — inaccessible and unhelpful for users and SEO",
    "ice": { "impact": 7, "confidence": 9, "ease": 8 },
    "target_selector": "a"
  },
  {
    "id": "ux-grammar-placeholder-text",
    "category": "grammar",
    "check": {
      "type": "text_content",
      "selectors": ["h1", "h2", "h3", "p", "span"],
      "condition": "placeholder_text"
    },
    "finding": "Element contains placeholder/Lorem Ipsum text that was not replaced",
