{
  "manifest_version": 3,
  "name": "EchoFlow",
  "version": "1.0.0",
  "description": "UX audit tool for websites — Generic UX, Shopify, Fintech, and Crypto verticals with ICE scoring.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["results.html", "offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
